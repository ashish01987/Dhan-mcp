# ── Dhan MCP Server Configuration (OAuth-Only) ──────────────────────────────────

# Client ID (required)
DHAN_CLIENT_ID=your_client_id_from_dhan_portal

# OAuth Credentials (required)
# Get from: https://dhan.co/developers
DHAN_APP_ID=your_app_id
DHAN_APP_SECRET=your_app_secret

# Server Configuration
MCP_PORT=3005
