# ── Dhan MCP Server Configuration ──────────────────────────────────────────────

# Client ID (required for all auth methods)
DHAN_CLIENT_ID=your_client_id

# ── Option A: OAuth Flow (Recommended) ─────────────────────────────────────────
# Secure user-driven authentication without storing passwords
# 1. Get APP_ID and APP_SECRET from Dhan developer portal
# 2. Set them below
# 3. Start server: docker compose up
# 4. Visit http://localhost:3005/oauth/login to get login URL
# 5. User authenticates and gets token_id in redirect URL
# 6. Exchange token_id at /oauth/callback?token_id=xxx
DHAN_APP_ID=your_app_id_from_dhan_portal
DHAN_APP_SECRET=your_app_secret_from_dhan_portal

# ── Option B: Static Access Token ──────────────────────────────────────────────
# Easiest but less secure. Get token from Dhan developer portal
DHAN_ACCESS_TOKEN=

# ── Server Configuration ──────────────────────────────────────────────────────
MCP_TRANSPORT=http
MCP_PORT=3005
